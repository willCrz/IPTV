{
  "name": "tv-web-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:titan": "NEXT_PUBLIC_PLATFORM=titan next build",
    "build:webos": "NEXT_PUBLIC_PLATFORM=webos next build",
    "build:androidtv": "NEXT_PUBLIC_PLATFORM=androidtv next build",
    "build:android": "npm run build:androidtv && npx cap sync android && npx cap build android",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out dist"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@iptv/cache-engine": "workspace:*",
    "@iptv/player-core": "workspace:*",
    "@iptv/shared-types": "workspace:*",
    "@iptv/ui-core": "workspace:*",
    "@sentry/nextjs": "^8.0.0",
    "@tanstack/react-query": "^5.40.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.2.0",
    "hls.js": "^1.5.0",
    "lucide-react": "^1.8.0",
    "next": "15.3.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-window": "^1.8.10",
    "tailwind-merge": "^2.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^1.8.8",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
