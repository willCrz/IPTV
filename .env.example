# ============================================================
# IPTV PRO - Environment Variables
# Desenvolvimento: copie para .env.local e preencha os valores
# Produção (Railway): configure no dashboard de cada serviço
#
# DEPLOY RAILWAY — ordem:
#   1. Criar projeto Railway + plugin Redis
#   2. Serviço "api-gateway" → root dir: backend/api-gateway
#        JWT_SECRET, CORS_ORIGIN, REDIS_URL (auto), PORT=3001
#   3. Serviço "tv-web-app" → root dir: / (raiz do repo)
#        NEXT_PUBLIC_API_URL=https://<api-gateway>.up.railway.app
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_NAME="IPTV Pro"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_PLATFORM="web"  # web | titan | webos | tizen | androidtv

# --- API ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
API_SECRET_KEY="your-secret-key-here"

# --- Backend ---
PORT=3001
NODE_ENV=development

# --- PostgreSQL ---
DATABASE_URL="postgresql://iptv_user:iptv_pass@localhost:5432/iptv_pro"
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iptv_pro
DB_USER=iptv_user
DB_PASSWORD=iptv_pass
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Redis ---
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# --- JWT ---
JWT_SECRET="your-jwt-secret-256-bit-key-here"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# --- Sentry ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Rate Limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# --- Health Check ---
HEALTH_CHECK_INTERVAL=30000
STREAM_TIMEOUT=10000
PING_TIMEOUT=5000

# --- CORS ---
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# --- Storage ---
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=52428800

# --- Xtream (default fallback) ---
DEFAULT_XTREAM_URL=
DEFAULT_XTREAM_USERNAME=
DEFAULT_XTREAM_PASSWORD=

# --- TMDB (sinopses e metadados) ---
# Grátis em: https://www.themoviedb.org/settings/api
NEXT_PUBLIC_TMDB_KEY=
